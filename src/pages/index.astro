---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/profile';
---

<BaseLayout title={`${profile.personal.firstName} ${profile.personal.lastName} - ${profile.personal.title}`}>
  <Header slot="header" />
  <section id="hero">
    <h1>Bienvenue sur mon portfolio</h1>
    <p>{profile.personal.subtitle}</p>
  </section>

  {profile.technicalSkills && Object.keys(profile.technicalSkills).length>0 && (
    <section id="skills">
      <h2>Compétences techniques</h2>
      <!-- list technical skills -->
    </section>
  )}

  {profile.education && profile.education.length > 0 && (
    <section id="education">
      <h2>Éducation</h2>
    </section>
  )}

  <section id="contact">
    <h2>Contact</h2>
    <p>Email: {profile.personal.email}</p>
  </section>

  <Footer slot="footer" />
</BaseLayout>
