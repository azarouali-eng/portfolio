---
/**
 * BaseLayout.astro
 * Main HTML wrapper used by pages. Responsible for global <head> tags,
 * theme initialization, and rendering Header/Footer components and slot.
 * All pages should import and use this layout.
 */
import type { AstroComponentFactory } from 'astro';

// data attributes are serialized into <html> by consuming components as needed.

const title = "Portfolio"; // will be replaced or built dynamically
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="theme-color" content="#0a0f1e" />
    <!-- inline script to initialize theme before render to avoid flash -->
    <script>
      // Theme initialization: restore from localStorage or system preference
      (function(){
        try {
          const theme = localStorage.getItem('theme');
          const el = document.documentElement;
          if (theme === 'light' || theme === 'dark') {
            el.setAttribute('data-theme', theme);
            document.querySelector('meta[name="theme-color"]').setAttribute('content', theme==='light' ? '#f8fafc' : '#0a0f1e');
          }
        } catch(e) {}
      })();
    </script>
    <style>
      /* global CSS custom properties and resets */
      :root {
        --bg: #0a0f1e;
        --text: #e2e8f0;
        --accent: #7f5af0;
        --primary: #2563eb;
        --muted: #475569;
        --glass-bg: rgba(255,255,255,0.07);
        --glass-border: rgba(255,255,255,0.15);
        --radius: 0.5rem;
        --transition: 0.3s ease;
      }
      html[data-theme="light"] {
        --bg: #f8fafc;
        --text: #0f172a;
        --accent: #7c3aed;
        --primary: #2563eb;
        --muted: #64748b;
        --glass-bg: rgba(255,255,255,0.4);
        --glass-border: rgba(0,0,0,0.1);
      }
      body {
        margin:0;
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
        scroll-behavior: smooth;
      }
      a { color: var(--primary); text-decoration:none; }
      a:focus { outline:2px solid var(--accent); }
      /* skip-link */
      .skip-link {
        position:absolute;top:-40px;left:0;
        background:var(--accent);color:#fff;padding:8px;
        z-index:1000;transition:top .3s;
      }
      .skip-link:focus { top:0; }
    </style>
    <slot name="head" /><!-- additional head content -->
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <!-- header will be inserted by page or here once created -->
    <slot name="header"></slot>
    <main id="main">
      <slot />
    </main>
    <slot name="footer"></slot>
    <!-- Vercel analytics injection placeholder -->
    <script type="module">
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
